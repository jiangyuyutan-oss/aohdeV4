{
    "_说明": "战斗配置 - Age of History II (文明时代 2) Mod 详细配置",
    "_使用方法": "复制此文件，删除不需要的行以恢复默认值。放在 APK 的 assets/mods/ 或 Android/data/<包名>/files/mods/ 目录下。",

    // ============================================================
    // GV_Battle - 科技等级战斗加成
    // ============================================================
    // 这些参数决定了科技等级如何影响军队的攻击力和防御力。

    // 科技等级带来的【基础】攻击加成 (默认: 110)
    // 每提升 1 级科技，军队攻击力额外增加 110%
    "TECHNOLOGY_LEVEL_BONUS_ARMY_ATTACK_DEFAULT": 110,

    // 科技等级带来的【最大】攻击加成上限 (默认: 300)
    // 攻击加成最高不能超过 300%
    "TECHNOLOGY_LEVEL_BONUS_ARMY_ATTACK_LIMIT": 300,

    // 科技等级带来的【基础】防御加成 (默认: 100)
    // 每提升 1 级科技，军队防御力额外增加 100%
    "TECHNOLOGY_LEVEL_BONUS_ARMY_DEFENSE_DEFAULT": 100,

    // 科技等级带来的【最大】防御加成上限 (默认: 300)
    // 防御加成最高不能超过 300%
    "TECHNOLOGY_LEVEL_BONUS_ARMY_DEFENSE_LIMIT": 300,

    // ============================================================
    // GV_Battle - 战斗省份损失
    // ============================================================
    // 战斗对所在省份造成的经济和人口损失。

    // 战斗中造成的【单位经济损失】系数 (默认: 0.00275)
    // 计算公式：损失金钱 = 参战军队总数 * 此系数
    // 值越大，战斗对当地经济破坏越严重
    "BATTLE_PROVINCE_ECONOMY_LOSSES_UNITS": 0.00275,

    // 战斗中造成的【经济损失最大百分比】 (默认: 0.035)
    // 单次战斗造成的金钱损失不能超过该省总收入的 3.5%
    // 如果想取消上限，可以设置为 1.0 (100%)
    "BATTLE_PROVINCE_ECONOMY_LOSSES_MAX_PERC": 0.035,

    // 【基础】人口损失率 (默认: 0.0305)
    // 每次战斗后，该省基础损失 3.05% 的人口
    "BATTLE_PROVINCE_POPULATION_LOSSES_BASE": 0.0305,

    // 科技等级对人口损失的【修正值】 (默认: 0.0065)
    // 科技等级越高，战争越残酷，人口损失越大
    "BATTLE_PROVINCE_POPULATION_LOSSES_TECH_LEVEL_MODIFIER": 0.0065,

    // 基于该省【总人口】比例的额外损失 (默认: 0.0025)
    // 人口越多的大省，绝对损失量越大
    "BATTLE_PROVINCE_POPULATION_LOSSES_OR_BASED_ON_POPULATION_PERC": 0.0025,

    // ============================================================
    // GV_Capital - 首都加成
    // ============================================================

    // 从首都发起进攻时的【攻击力加成】 (默认: 10)
    // 部队从首都出发攻击敌人时，攻击力 +10%
    "BONUS_CAPITAL_ATTACK_FROM_CAPITAL": 10,

    // 首都省份的【防御力加成】 (默认: 20)
    // 敌人进攻你的首都省份时，守军防御力 +20%
    "BONUS_CAPITAL_DEFENSE": 20,

    // ============================================================
    // GV_BuildingFort - 要塞建筑防御加成
    // ============================================================
    // 这里对应 FORT_DEFENSE_BONUS 数组的索引 [0, 1, 2]

    // 索引 0: 【基础】要塞 (默认: 0)
    "FORT_DEFENSE_BONUS_FORT": 0,

    // 索引 1: 【城堡】 (默认: 10)
    "FORT_DEFENSE_BONUS_CASTLE": 10,

    // 索引 2: 【大型堡垒】 (默认: 20)
    "FORT_DEFENSE_BONUS_FORTRESS": 20,

    // ============================================================
    // GV_BuildingWatchTower - 瞭望塔防御加成
    // ============================================================
    // 这里对应 TOWER_DEFENSE_BONUS 数组的索引 [0, 1]

    // 索引 0: 【基础】瞭望塔 (默认: 0)
    "TOWER_DEFENSE_BONUS_BASE": 0,

    // 索引 1: 【高级】瞭望塔 (默认: 4)
    "TOWER_DEFENSE_BONUS": 4,

    // ============================================================
    // GV_Military - 军事专家 (Military Expertise) 属性
    // ============================================================
    // 军事专家是通过点数升级的特殊技能，影响军队整体属性。

    // 每点军事专家带来的【攻击加成】 (默认: 1.5)
    "MILITARY_EXPERTISE_ATTACK_PER_POINT": 1.5,

    // 每点军事专家带来的【防御加成】 (默认: 1.25)
    "MILITARY_EXPERTISE_DEFENSE_PER_POINT": 1.25,

    // 军事专家的【最高等级】 (默认: 20)
    "MILITARY_EXPERTISE_MAX_LEVEL": 20,

    // 军事专家带来的【最大攻击加成上限】 (默认: 10)
    // 即使加点再多，攻击加成也不会超过此值
    "MILITARY_EXPERTISE_MAX_ATTACK": 10,

    // 军事专家带来的【最大防御加成上限】 (默认: 10)
    "MILITARY_EXPERTISE_MAX_DEFENSE": 10
}
